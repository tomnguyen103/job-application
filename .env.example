# =============================================================================
# Environment variables for JobApplication
# -----------------------------------------------------------------------------
# This is a TEMPLATE. Copy it to .env.local for local development and fill in
# real values. NEVER put real secrets in this file — it is committed to git.
#
#   cp .env.example .env.local
#
# On Vercel, do NOT rely on a committed env file. Set these in
# Settings -> Environment Variables, scoped per environment
# (Production / Preview / Development).
#
# NOTE: every NEXT_PUBLIC_* value is inlined at BUILD time. Changing one in
# Vercel requires a REDEPLOY before it takes effect.
# =============================================================================

# -----------------------------------------------------------------------------
# Public — exposed to the browser (build-time). Safe to be public.
# -----------------------------------------------------------------------------

# InsForge backend (API base + anon/publishable key)
NEXT_PUBLIC_INSFORGE_URL=https://your-project.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-insforge-anon-key

# App origin — used to build the OAuth callback URL.
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app   (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics — browser client (event capture)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Secret — server-side only. NEVER add a NEXT_PUBLIC_ prefix to these.
# -----------------------------------------------------------------------------

# AI provider — Google Gemini 2.5-flash via @google/genai
# (agent: job matching, extraction, resume generation, company research)
GEMINI_API_KEY=your-gemini-api-key

# Browserbase — cloud browser for company research
BROWSERBASE_API_KEY=bb_your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# Adzuna — job discovery API
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# PostHog server-side query API (powers dashboard analytics charts)
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key
POSTHOG_PROJECT_ID=your-posthog-project-id
POSTHOG_API_HOST=https://us.posthog.com

# InsForge scheduled cleanup for temporary tailored resumes
# TAILORED_RESUME_CLEANUP_API_KEY is the bearer token expected by the schedule.
# INSFORGE_ADMIN_API_KEY must stay server-side/admin only.
TAILORED_RESUME_CLEANUP_API_KEY=your-cleanup-bearer-token
INSFORGE_ADMIN_API_KEY=your-insforge-admin-api-key
INSFORGE_BASE_URL=https://your-project.us-east.insforge.app
